# Copia este archivo como .env y ajusta los valores para tu entorno local.
# No subas frontend/.env al repositorio.

# URL base del backend que consume la app Flutter.
BACKEND_URL=https://nivroy-tiki-tiki-backend.onrender.com

# Usuario de TikTok Live sin @. Dejalo vacio si lo configuraras desde la app.
TIKTOK_USERNAME=

# API local del plugin ServerTap instalado en tu servidor Minecraft.
SERVERTAP_URL=http://127.0.0.1:4567

# Si en plugins/ServerTap/config.yml tienes useKeyAuth: true, coloca el key aqui.
SERVERTAP_KEY=change_me
